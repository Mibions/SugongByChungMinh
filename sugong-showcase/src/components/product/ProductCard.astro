---
import { Gift, Heart, Scissors, Sparkles, WandSparkles } from "lucide-react";
import type { Product } from "../../domain/product/product.types";
import { withBase } from "../../lib/url";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const image = product.images.toSorted((a, b) => a.sortOrder - b.sortOrder)[0];
const categoryIcons: Partial<Record<Product["category"], typeof Gift>> = {
  gift: Gift,
  graduation: Gift,
  custom: WandSparkles,
};
const CategoryIcon = categoryIcons[product.category] ?? Scissors;
---

<article class="group flex h-full flex-col overflow-hidden rounded-card border border-primary-soft/45 bg-background-card shadow-soft transition duration-300 hover:-translate-y-1 hover:border-primary-soft hover:shadow-feather">
  <a class="group block" href={withBase(`/products/${product.slug}`)} aria-label={`Xem ${product.name}`}>
    <div class="relative aspect-[4/3] overflow-hidden bg-background-section">
      <img
        class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
        src={withBase(image.url)}
        alt={image.alt}
        width={image.width}
        height={image.height}
        loading="lazy"
      />
      <span
        class="absolute right-3 top-3 flex h-9 w-9 items-center justify-center rounded-full bg-background-card/90 text-primary shadow-feather ring-1 ring-primary-soft/30"
        aria-hidden="true"
      >
        <Heart size={18} />
      </span>
    </div>
  </a>
  <div class="flex flex-1 flex-col space-y-4 p-5">
    <div class="space-y-2">
      <div class="flex flex-wrap items-center gap-2">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-background-section px-3 py-1 text-xs font-medium text-primary-dark">
          <CategoryIcon size={13} aria-hidden="true" />
          Handmade
        </span>
        {product.customizable && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-primary-soft/45 px-3 py-1 text-xs font-medium text-primary-dark">
            <WandSparkles size={13} aria-hidden="true" />
            Custom
          </span>
        )}
      </div>
      <h3 class="font-heading text-xl leading-snug text-primary-dark">{product.name}</h3>
      <p class="text-sm font-semibold text-text-primary">{product.formattedPrice}</p>
    </div>
    <a
      class="mt-auto inline-flex items-center gap-2 text-sm font-medium text-primary-dark transition hover:text-text-primary"
      href={withBase(`/products/${product.slug}`)}
    >
      Xem chi tiết
      <Sparkles size={15} aria-hidden="true" />
    </a>
  </div>
</article>
