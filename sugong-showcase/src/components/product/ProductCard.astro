---
import type { Product } from "../../domain/product/product.types";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const image = product.images.toSorted((a, b) => a.sortOrder - b.sortOrder)[0];
---

<article class="overflow-hidden rounded-card bg-background-card shadow-feather ring-1 ring-primary-soft/20">
  <a class="group block" href={`/products/${product.slug}`} aria-label={`Xem ${product.name}`}>
    <div class="relative aspect-[4/3] overflow-hidden bg-background-section">
      <img
        class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
        src={image.url}
        alt={image.alt}
        width={image.width}
        height={image.height}
        loading="lazy"
      />
      <span
        class="absolute right-3 top-3 flex h-9 w-9 items-center justify-center rounded-full bg-background-card/90 text-xl text-primary shadow-feather ring-1 ring-primary-soft/20"
        aria-hidden="true"
      >
        ♡
      </span>
    </div>
  </a>
  <div class="space-y-3 p-4">
    <div class="space-y-1.5">
      <h3 class="font-heading text-xl leading-snug text-primary-dark">{product.name}</h3>
      <p class="text-sm font-semibold text-text-primary">{product.formattedPrice}</p>
      {product.customizable && <p class="text-xs font-medium text-success">Có thể custom</p>}
    </div>
    <a
      class="inline-flex items-center gap-2 text-sm font-medium text-primary-dark transition hover:text-text-primary"
      href={`/products/${product.slug}`}
    >
      Xem chi tiết <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
