---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md";
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className,
} = Astro.props;

const classes = [
  "inline-flex items-center justify-center rounded-button font-medium transition",
  "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2",
  size === "sm" ? "min-h-9 px-4 text-sm" : "min-h-11 px-5 text-sm sm:text-base",
  variant === "primary" && "bg-primary text-background-card shadow-soft hover:bg-primary-dark",
  variant === "secondary" &&
    "bg-background-card/80 text-primary-dark shadow-[inset_0_0_0_1px_rgb(228_218_239/70%)] hover:shadow-[inset_0_0_0_1px_rgb(217_200_236/100%)]",
  variant === "ghost" && "text-primary-dark hover:bg-background-section",
  className,
];
---

{
  href ? (
    <a class:list={classes} href={href}>
      <slot />
    </a>
  ) : (
    <button class:list={classes} type="button">
      <slot />
    </button>
  )
}
