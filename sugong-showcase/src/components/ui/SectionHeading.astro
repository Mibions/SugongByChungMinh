---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
---

<div class:list={["max-w-2xl", align === "center" && "mx-auto text-center"]}>
  {eyebrow && <p class="mb-3 text-sm font-medium uppercase text-primary-dark">{eyebrow}</p>}
  <h2 class="font-heading text-3xl leading-tight text-text-primary sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-text-secondary">{description}</p>}
</div>
