---
import "../styles/global.css";
import Button from "../components/ui/Button.astro";
import Container from "../components/ui/Container.astro";
import { MobileNavigation } from "../features/mobile-navigation/MobileNavigation";
import { createSeo, type SeoInput } from "../lib/seo";
import { brand, navigationItems } from "../lib/site-data";

interface Props extends SeoInput {}

const seo = createSeo(Astro.props);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={seo.description} />
    <title>{seo.title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background-main text-text-primary antialiased">
    <header class="sticky top-0 z-50 bg-background-main/90 shadow-[0_1px_0_rgb(228_218_239/45%)] backdrop-blur">
      <Container class="flex h-header max-w-wide items-center justify-between gap-6">
        <a class="font-heading text-2xl font-bold tracking-normal text-primary-dark" href="/">SUGONG</a>
        <nav class="hidden items-center gap-7 text-sm font-medium text-text-secondary md:flex" aria-label="Điều hướng chính">
          {navigationItems.map((item) => (
            <a
              class:list={[
                "hover:text-primary-dark",
                currentPath === item.href || currentPath.startsWith(`${item.href}/`)
                  ? "text-primary-dark"
                  : "text-text-secondary",
              ]}
              href={item.href}
              aria-current={currentPath === item.href || currentPath.startsWith(`${item.href}/`) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="flex items-center gap-3">
          <Button href={brand.channels.zalo} size="sm">Đặt hàng</Button>
          <MobileNavigation items={navigationItems} currentPath={currentPath} client:load />
        </div>
      </Container>
    </header>
    <main>
      <slot />
    </main>
    <footer class="bg-background-card py-10 shadow-[0_-1px_0_rgb(228_218_239/38%)]">
      <Container class="grid max-w-wide gap-8 text-sm text-text-secondary md:grid-cols-[1.1fr_1fr_1fr] md:items-start">
        <div class="space-y-3">
          <p class="font-heading text-2xl text-primary-dark">{brand.name}</p>
          <p class="max-w-sm leading-6">{brand.description}</p>
        </div>
        <nav class="grid gap-3" aria-label="Điều hướng chân trang">
          {navigationItems.map((item) => <a class="hover:text-primary-dark" href={item.href}>{item.label}</a>)}
        </nav>
        <div class="grid gap-3">
          <a class="hover:text-primary-dark" href="/about#tiktok">TikTok {brand.channels.tiktok}</a>
          <a class="hover:text-primary-dark" href="/about">Instagram {brand.channels.instagram}</a>
          <a class="hover:text-primary-dark" href={brand.channels.zalo}>Zalo</a>
        </div>
      </Container>
    </footer>
  </body>
</html>
