---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createProductService } from "../../lib/products";
import ProductsHeader from "../../sections/products/ProductsHeader.astro";
import { ProductListingClient } from "../../sections/products/ProductListingClient";
import { brand } from "../../lib/site-data";

const productService = await createProductService();
const products = await productService.getProducts();
---

<BaseLayout
  title="Sản phẩm"
  description="Khám phá những sản phẩm handmade được làm thủ công và có thể thiết kế theo yêu cầu."
>
  <ProductsHeader />
  <ProductListingClient products={products} zaloHref={brand.channels.zalo} client:idle />
</BaseLayout>
