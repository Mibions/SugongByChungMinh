---
import { ArrowLeft, ChevronRight, MessageCircle, PlayCircle, Sparkles } from "lucide-react";
import Button from "../../../components/ui/Button.astro";
import Container from "../../../components/ui/Container.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { graduationHatTones } from "../../../domain/graduation-hat/graduation-hat.types";
import { createGraduationHatService } from "../../../lib/graduation-hats";
import { brand } from "../../../lib/site-data";
import { withBase } from "../../../lib/url";

export async function getStaticPaths() {
  const graduationHatService = createGraduationHatService();
  const hats = await graduationHatService.getGraduationHats();

  return hats.map((hat) => ({
    params: { slug: hat.slug },
    props: { hat },
  }));
}

const { hat } = Astro.props;
const toneLabel = graduationHatTones.find((item) => item.value === hat.tone)?.label ?? "Khác";
const gallery = hat.gallery.length > 0 ? hat.gallery : [hat.coverImage];
---

<BaseLayout title={hat.name} description={hat.shortDescription}>
  <section class="py-section-mobile lg:py-section-desktop">
    <Container class="max-w-wide">
      <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <a class="inline-flex w-fit items-center gap-2 text-sm font-medium text-primary-dark hover:text-text-primary" href={withBase("/products/graduation-hats")}>
          <ArrowLeft size={16} aria-hidden="true" />
          Quay lại nón tốt nghiệp
        </a>
        <nav class="flex items-center gap-2 text-xs text-text-secondary" aria-label="Breadcrumb">
          <a class="hover:text-primary-dark" href={withBase("/")}>Trang chủ</a>
          <ChevronRight size={14} aria-hidden="true" />
          <a class="hover:text-primary-dark" href={withBase("/products")}>Sản phẩm</a>
          <ChevronRight size={14} aria-hidden="true" />
          <a class="hover:text-primary-dark" href={withBase("/products/graduation-hats")}>Nón tốt nghiệp</a>
          <ChevronRight size={14} aria-hidden="true" />
          <span class="text-primary-dark">{hat.name}</span>
        </nav>
      </div>

      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(360px,0.85fr)] lg:items-start">
        <div class="space-y-4">
          <div class="overflow-hidden rounded-card border border-primary-soft/45 bg-background-card p-3 shadow-feather">
            <img
              class="aspect-[4/5] w-full rounded-[14px] object-cover"
              src={withBase(hat.coverImage.url)}
              alt={hat.coverImage.alt}
              width="900"
              height="1200"
              loading="eager"
            />
          </div>
          {gallery.length > 1 && (
            <div class="flex gap-3 overflow-x-auto pb-1">
              {gallery.map((image) => (
                <img
                  class="h-24 w-24 shrink-0 rounded-card border border-primary-soft/45 bg-background-card object-cover p-1 shadow-soft"
                  src={withBase(image.url)}
                  alt={image.alt}
                  width="160"
                  height="160"
                  loading="lazy"
                />
              ))}
            </div>
          )}
        </div>

        <aside class="rounded-card border border-primary-soft/45 bg-background-card p-6 shadow-feather lg:sticky lg:top-24">
          <p class="inline-flex items-center gap-2 rounded-full bg-background-section px-4 py-2 text-xs font-semibold uppercase text-primary-dark">
            <Sparkles size={15} aria-hidden="true" />
            {toneLabel}
          </p>
          <h1 class="mt-4 font-heading text-4xl leading-tight text-primary-dark sm:text-5xl">{hat.name}</h1>
          <p class="mt-4 text-base leading-7 text-text-secondary">{hat.shortDescription}</p>
          {hat.description && <p class="mt-4 text-sm leading-7 text-text-secondary">{hat.description}</p>}

          <div class="mt-6 flex flex-wrap gap-2">
            {hat.tags.map((tag) => (
              <span class="rounded-full bg-background-section px-3 py-1 text-xs font-medium text-primary-dark">
                {tag}
              </span>
            ))}
          </div>

          <div class="mt-7 rounded-card bg-background-section p-5">
            <h2 class="font-heading text-2xl text-primary-dark">Thích mẫu này?</h2>
            <p class="mt-2 text-sm leading-6 text-text-secondary">
              Nhắn SUGONG để trao đổi mẫu tương tự, tone màu và thời gian hoàn thiện.
            </p>
            <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
              <Button class="gap-2" href={brand.channels.zalo}>
                <MessageCircle size={17} aria-hidden="true" />
                Nhắn Zalo
              </Button>
              <Button class="gap-2" href={hat.tiktokUrl ?? brand.tiktokProfileUrl} variant="secondary">
                <PlayCircle size={17} aria-hidden="true" />
                Xem TikTok
              </Button>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>
