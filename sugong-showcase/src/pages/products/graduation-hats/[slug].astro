---
import { ArrowLeft, ChevronRight, MessageCircle, PlayCircle, Sparkles } from "lucide-react";
import { ProductGallery } from "../../../components/product/ProductGallery";
import Button from "../../../components/ui/Button.astro";
import Container from "../../../components/ui/Container.astro";
import { graduationHatTones } from "../../../domain/graduation-hat/graduation-hat.types";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getGraduationHats } from "../../../lib/catalog";
import { brand } from "../../../lib/site-data";
import { withBase } from "../../../lib/url";

export async function getStaticPaths() {
  const hats = await getGraduationHats();

  return hats.map((hat) => ({
    params: { slug: hat.slug },
    props: { hat },
  }));
}

const { hat } = Astro.props;
const toneLabel = graduationHatTones.find((item) => item.value === hat.tone)?.label ?? "Khác";
const galleryImages = (hat.gallery.length > 0 ? hat.gallery : [hat.coverImage]).map((image, index) => ({
  ...image,
  sortOrder: index,
}));
---

<BaseLayout title={hat.name} description={hat.shortDescription}>
  <section class="bg-background-card/45 py-section-mobile lg:py-section-desktop">
    <Container class="max-w-[1160px]">
      <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <a class="inline-flex w-fit items-center gap-2 text-sm font-medium text-primary-dark hover:text-text-primary" href={withBase("/products/graduation-hats")}>
          <ArrowLeft size={16} aria-hidden="true" />
          Quay lại nón tốt nghiệp
        </a>
        <nav class="flex flex-wrap items-center gap-2 text-xs text-text-secondary" aria-label="Breadcrumb">
          <a class="hover:text-primary-dark" href={withBase("/")}>Trang chủ</a>
          <ChevronRight size={14} aria-hidden="true" />
          <a class="hover:text-primary-dark" href={withBase("/products")}>Sản phẩm</a>
          <ChevronRight size={14} aria-hidden="true" />
          <a class="hover:text-primary-dark" href={withBase("/products/graduation-hats")}>Nón tốt nghiệp</a>
          <ChevronRight size={14} aria-hidden="true" />
          <span class="text-primary-dark">{hat.name}</span>
        </nav>
      </div>

      <div class="grid gap-7 xl:grid-cols-[minmax(0,560px)_minmax(320px,380px)] xl:items-start xl:justify-center xl:gap-9">
        <div class="min-w-0 rounded-[22px] border border-primary-soft/35 bg-background-card p-3 shadow-feather sm:p-4">
          <div class="rounded-[18px] bg-background-main/60 p-2.5 sm:p-3">
            <ProductGallery
              images={galleryImages}
              productName={hat.name}
              client:visible
            />
          </div>
        </div>

        <aside class="space-y-5 xl:pt-2">
          <div class="space-y-5 rounded-[20px] border border-primary-soft/55 bg-background-card p-5 shadow-feather sm:p-6">
            <div class="space-y-3">
              <p class="inline-flex items-center gap-2 rounded-full bg-background-section px-4 py-2 text-xs font-semibold uppercase text-primary-dark">
                <Sparkles size={15} aria-hidden="true" />
                {toneLabel}
              </p>
              <h1 class="font-heading text-3xl leading-tight text-primary-dark sm:text-4xl">{hat.name}</h1>
              <p class="text-sm leading-7 text-text-secondary sm:text-base">{hat.shortDescription}</p>
              {hat.description && <p class="text-sm leading-7 text-text-secondary">{hat.description}</p>}
            </div>

            <div class="flex flex-wrap gap-2 border-y border-border py-4">
              {hat.tags.map((tag) => (
                <span class="rounded-full bg-background-section px-3 py-1 text-xs font-medium text-primary-dark">
                  {tag}
                </span>
              ))}
            </div>

            <div class="rounded-[18px] bg-background-section p-5">
              <h2 class="font-heading text-2xl text-primary-dark">Thích mẫu này?</h2>
              <p class="mt-2 text-sm leading-6 text-text-secondary">
                Nhắn SUGONG để trao đổi mẫu tương tự, tone màu và thời gian hoàn thiện.
              </p>
              <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                <Button class="gap-2" href={brand.channels.zalo}>
                  <MessageCircle size={17} aria-hidden="true" />
                  Nhắn Zalo
                </Button>
                <Button class="gap-2" href={hat.tiktokUrl ?? brand.tiktokProfileUrl} variant="secondary">
                  <PlayCircle size={17} aria-hidden="true" />
                  Xem TikTok
                </Button>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>
