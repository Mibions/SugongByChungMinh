---
import { MessageCircle, PlayCircle, Sparkles } from "lucide-react";
import Button from "../../components/ui/Button.astro";
import Container from "../../components/ui/Container.astro";
import { brand } from "../../lib/site-data";
---

<section class="bg-background-card pb-section-mobile lg:pb-section-desktop">
  <Container class="max-w-wide">
    <div class="relative overflow-hidden rounded-card border border-primary-soft/45 bg-background-section p-6 shadow-feather md:p-9">
      <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div class="max-w-2xl">
          <p class="inline-flex items-center gap-2 rounded-full bg-background-card/80 px-4 py-2 text-xs font-semibold uppercase text-primary-dark shadow-soft">
            <Sparkles size={15} aria-hidden="true" />
            Liên hệ nhẹ nhàng
          </p>
          <h2 class="mt-4 font-heading text-3xl text-primary-dark sm:text-4xl">
            Bạn thích mẫu nào của SUGONG?
          </h2>
          <p class="mt-3 text-sm leading-7 text-text-secondary">
            Nhắn tụi mình qua Zalo, TikTok hoặc Threads để hỏi thêm về mẫu, giá và thời gian hoàn thiện nhé.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-1 lg:grid-cols-2">
          <Button href={brand.channels.zalo} class="gap-2">
            <MessageCircle size={17} aria-hidden="true" />
            Nhắn Zalo
          </Button>
          <Button href={brand.tiktokProfileUrl} variant="secondary" class="gap-2">
            <PlayCircle size={17} aria-hidden="true" />
            Xem TikTok
          </Button>
        </div>
      </div>
    </div>
  </Container>
</section>
