---
import { PlayCircle, ShoppingBag, Sparkles } from "lucide-react";
import Container from "../../components/ui/Container.astro";
import { brand } from "../../lib/site-data";
import { withBase } from "../../lib/url";

const cards = [
  {
    title: "Túi handmade",
    caption: "Góc túi lavender nhẹ nhàng, hợp đi học, đi chơi và làm quà.",
    image: "/assets/products/bag-lavender-poster.svg",
    href: "/products?category=bag",
  },
  {
    title: "Set quà tặng",
    caption: "Những set quà nhỏ xinh, phối màu dịu và đóng gói chỉn chu.",
    image: "/assets/products/giftbox-bear.svg",
    href: "/products?category=gift",
  },
  {
    title: "Phụ kiện nhỏ",
    caption: "Móc khóa, túi thêu tên và những chi tiết có thể trao đổi thêm.",
    image: "/assets/products/custom-keychain.svg",
    href: brand.tiktokProfileUrl,
  },
];
---

<section id="tiktok" class="bg-background-main py-section-mobile lg:py-section-desktop">
  <Container class="max-w-wide">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="inline-flex items-center gap-2 text-sm font-semibold uppercase text-primary-dark">
          <PlayCircle size={16} aria-hidden="true" />
          Từ TikTok đến sản phẩm thật
        </p>
        <h2 class="mt-2 font-heading text-3xl text-primary-dark sm:text-4xl">
          Những mẫu SUGONG được chia sẻ qua video ngắn
        </h2>
        <p class="mt-3 text-sm leading-7 text-text-secondary">
          Xem trước cảm giác chất liệu, màu sắc và cách SUGONG phối những món quà handmade.
        </p>
      </div>
      <a
        class="inline-flex min-h-11 w-fit items-center justify-center gap-2 rounded-button border border-primary-soft bg-background-card px-5 text-sm font-medium text-primary-dark shadow-soft transition hover:bg-background-section"
        href={brand.tiktokProfileUrl}
      >
        <Sparkles size={16} aria-hidden="true" />
        Xem TikTok
      </a>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {cards.map((card) => (
        <article class="overflow-hidden rounded-card border border-primary-soft/45 bg-background-card p-3 shadow-soft">
          <a class="group block" href={withBase(card.href)} aria-label={card.title}>
            <div class="relative aspect-[9/16] overflow-hidden rounded-[14px] bg-background-section">
              <img
                class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.025]"
                src={withBase(card.image)}
                alt={card.title}
                width="900"
                height="1600"
                loading="lazy"
              />
              <span class="absolute left-3 top-3 inline-flex items-center gap-1.5 rounded-full bg-background-card/90 px-3 py-1 text-xs font-semibold text-primary-dark shadow-soft">
                <PlayCircle size={14} aria-hidden="true" />
                Video
              </span>
              <span class="absolute bottom-3 right-3 grid h-11 w-11 place-items-center rounded-full bg-background-card/90 text-primary-dark shadow-soft">
                <ShoppingBag size={18} aria-hidden="true" />
              </span>
            </div>
            <div class="p-2 pt-4">
              <h3 class="font-heading text-2xl text-primary-dark">{card.title}</h3>
              <p class="mt-2 text-sm leading-6 text-text-secondary">{card.caption}</p>
              <p class="mt-3 text-sm font-medium text-primary-dark">Xem thêm</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </Container>
</section>
