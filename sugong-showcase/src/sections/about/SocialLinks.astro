---
import { AtSign, Camera, ExternalLink, MessageCircle, PlayCircle } from "lucide-react";
import Button from "../../components/ui/Button.astro";
import Container from "../../components/ui/Container.astro";
import { socialLinks } from "../../lib/site-data";
import { withBase } from "../../lib/url";

const icons: Record<string, typeof MessageCircle> = {
  Zalo: MessageCircle,
  TikTok: PlayCircle,
  Threads: AtSign,
  Instagram: Camera,
};
---

<section id="social" class="bg-background-card py-section-mobile lg:py-section-desktop">
  <Container class="max-w-wide">
    <div class="mb-8 max-w-2xl">
      <p class="text-sm font-semibold uppercase text-primary-dark">Kết nối với SUGONG</p>
      <h2 class="mt-2 font-heading text-3xl text-primary-dark sm:text-4xl">
        Xem thêm sản phẩm và nhắn tụi mình
      </h2>
      <p class="mt-3 text-sm leading-7 text-text-secondary">
        Zalo là kênh liên hệ chính. TikTok, Threads và Instagram dùng để xem thêm hình ảnh, video và các mẫu mới.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {socialLinks.map((item) => {
        const Icon = icons[item.name] ?? MessageCircle;

        return (
          <article class="flex h-full flex-col rounded-card border border-primary-soft/45 bg-background-main p-5 shadow-soft">
            <span class="grid h-12 w-12 place-items-center rounded-full bg-background-card text-primary-dark shadow-soft">
              <Icon size={21} aria-hidden="true" />
            </span>
            <h3 class="mt-5 font-heading text-2xl text-primary-dark">{item.name}</h3>
            <p class="mt-2 flex-1 text-sm leading-6 text-text-secondary">{item.description}</p>
            <div class="mt-5">
              {item.primary ? (
                <Button href={item.href} class="w-full gap-2">
                  <MessageCircle size={16} aria-hidden="true" />
                  {item.cta}
                </Button>
              ) : (
                <a
                  class="inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-button border border-primary-soft bg-background-card px-4 text-sm font-medium text-primary-dark transition hover:bg-background-section"
                  href={withBase(item.href)}
                >
                  {item.cta}
                  <ExternalLink size={15} aria-hidden="true" />
                </a>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </Container>
</section>
