---
import Button from "../../components/ui/Button.astro";
import { isProductCustomizable } from "../../domain/product/product.helpers";
import { productCategoryMeta } from "../../domain/product/product-taxonomy";
import type { Product } from "../../domain/product/product.types";
import { brand } from "../../lib/site-data";
import { MessageCircle, Palette, Ruler, Scissors, ShoppingBag, Sparkles, WandSparkles } from "lucide-react";

interface Props {
  product: Product;
}

const { product } = Astro.props;

const detailItems = product.detailItems?.length
  ? product.detailItems
  : [
      { label: "Danh mục", value: productCategoryMeta[product.category].label },
      { label: "Custom", value: isProductCustomizable(product) ? "Có thể custom" : "Mẫu có sẵn" },
    ];

function getRowIcon(label: string) {
  const normalized = label.toLocaleLowerCase("vi");
  if (normalized.includes("màu") || normalized.includes("tone")) return Palette;
  if (normalized.includes("kích thước") || normalized.includes("size")) return Ruler;
  if (normalized.includes("custom") || normalized.includes("cá nhân")) return WandSparkles;
  if (normalized.includes("chất liệu") || normalized.includes("vải") || normalized.includes("canvas")) return Scissors;
  return Sparkles;
}
---

<aside class="space-y-5">
  <div class="space-y-5 rounded-[20px] border border-primary-soft/55 bg-background-card p-5 shadow-feather sm:p-6">
    <div class="space-y-3">
      <p class="inline-flex items-center gap-2 rounded-full bg-background-section px-4 py-2 text-xs font-semibold uppercase text-primary-dark">
        <ShoppingBag size={15} aria-hidden="true" />
        {productCategoryMeta[product.category].label}
      </p>
      <h1 class="font-heading text-3xl leading-tight text-primary-dark sm:text-4xl">{product.name}</h1>
      <p class="text-xl font-semibold text-primary-dark sm:text-2xl">{product.formattedPrice}</p>
      <p class="text-sm leading-7 text-text-secondary sm:text-base">{product.shortDescription}</p>
    </div>

    {detailItems.length > 0 && (
      <div class="grid gap-3 border-y border-border py-4">
        {detailItems.map((row) => {
          const Icon = getRowIcon(row.label);

          return (
            <div class="flex items-center gap-3 rounded-[18px] bg-background-section/70 p-3">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-background-card text-primary-dark shadow-soft">
                <Icon size={17} aria-hidden="true" />
              </span>
              <div>
                <p class="text-xs font-medium text-text-secondary">{row.label}</p>
                <p class="text-sm font-semibold text-text-primary">{row.value}</p>
              </div>
            </div>
          );
        })}
      </div>
    )}

    <div class="grid gap-3 sm:grid-cols-2">
      <Button class="w-full gap-2" href={brand.channels.zalo}>
        <MessageCircle size={17} aria-hidden="true" />
        Nhắn Zalo
      </Button>
      <Button class="w-full gap-2" href={brand.tiktokProfileUrl} variant="secondary">
        <Sparkles size={17} aria-hidden="true" />
        Xem TikTok
      </Button>
    </div>

    {product.detailNote && (
      <p class="rounded-[18px] bg-background-section p-4 text-xs leading-6 text-text-secondary">
        {product.detailNote}
      </p>
    )}
  </div>
</aside>
