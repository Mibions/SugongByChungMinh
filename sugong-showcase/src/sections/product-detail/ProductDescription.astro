---
import { ChevronDown, FileText, Info, WandSparkles } from "lucide-react";
import type { Product } from "../../domain/product/product.types";
import Container from "../../components/ui/Container.astro";

interface Props {
  product: Product;
}

const { product } = Astro.props;

const panels = [
  {
    title: "Mô tả",
    icon: FileText,
    content: product.description,
  },
  {
    title: "Custom",
    icon: WandSparkles,
    content: product.customizable
      ? "Bạn có thể nhắn SUGONG để đổi màu, thêu tên hoặc điều chỉnh chi tiết nhỏ theo câu chuyện riêng."
      : "Mẫu hiện được làm theo thiết kế có sẵn. SUGONG vẫn có thể tư vấn biến tấu nhẹ nếu bạn cần.",
  },
  {
    title: "Lưu ý",
    icon: Info,
    content: "Mỗi sản phẩm handmade có thể chênh nhẹ về chi tiết. SUGONG sẽ xác nhận mẫu, thời gian làm và phí giao hàng trước khi thực hiện.",
  },
];
---

<section class="bg-background-card py-section-mobile lg:py-section-desktop">
  <Container class="max-w-wide">
    <div class="grid gap-4 md:grid-cols-3">
      {panels.map((panel, index) => {
        const Icon = panel.icon;

        return (
          <details
            class="group rounded-card border border-primary-soft/40 bg-background-main p-5 shadow-soft md:open"
            open={index === 0}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-primary-dark">
              <span class="inline-flex items-center gap-3 font-heading text-2xl">
                <span class="grid h-10 w-10 place-items-center rounded-full bg-background-card text-primary-dark shadow-soft">
                  <Icon size={18} aria-hidden="true" />
                </span>
                {panel.title}
              </span>
              <ChevronDown className="shrink-0 text-primary-soft transition group-open:rotate-180" size={18} aria-hidden="true" />
            </summary>
            <p class="mt-4 text-sm leading-7 text-text-secondary">{panel.content}</p>
          </details>
        );
      })}
    </div>
  </Container>
</section>
