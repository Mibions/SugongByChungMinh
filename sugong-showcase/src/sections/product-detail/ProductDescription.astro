---
import type { Product } from "../../domain/product/product.types";
import { FileText, Info, WandSparkles } from "lucide-react";

interface Props {
  product: Product;
}

const { product } = Astro.props;

const panels = [
  {
    title: "Mô tả",
    icon: FileText,
    content: product.description ?? product.shortDescription,
  },
  {
    title: "Custom",
    icon: WandSparkles,
    content: product.customizable
      ? "Có thể thêu tên, đổi màu phụ kiện hoặc phối chi tiết nhỏ theo phong cách riêng."
      : "Sản phẩm hiện ưu tiên bán theo mẫu hoàn thiện để giữ đúng form và chất liệu.",
  },
  {
    title: "Lưu ý",
    icon: Info,
    content:
      "Mỗi sản phẩm handmade có thể chênh nhẹ về chi tiết. Hãy nhắn SUGONG để xác nhận mẫu, thời gian làm và phí giao hàng.",
  },
];
---

<section class="bg-background-card py-section-mobile lg:py-section-desktop">
  <div class="mx-auto w-full max-w-page px-5 sm:px-6 lg:px-8">
    <div class="grid gap-4 lg:grid-cols-3">
      {panels.map((panel) => {
        const Icon = panel.icon;

        return (
          <article class="rounded-card border border-primary-soft/55 bg-background-card p-6 shadow-soft">
            <div class="flex items-center gap-3">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-background-section text-primary-dark">
                <Icon size={18} aria-hidden="true" />
              </span>
              <p class="font-heading text-2xl text-primary-dark">{panel.title}</p>
            </div>
            <p class="mt-4 text-sm leading-7 text-text-secondary">{panel.content}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>
