---
import Button from "../../components/ui/Button.astro";
import Container from "../../components/ui/Container.astro";
import { brand } from "../../lib/site-data";
import { MessageCircle, Sparkles } from "lucide-react";
---

<section class="bg-background-card pb-section-mobile">
  <Container>
    <div class="relative overflow-hidden rounded-card border border-primary-soft/55 bg-background-section p-6 shadow-feather md:p-8">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgb(243_216_229/80%),transparent_34%),radial-gradient(circle_at_90%_0%,rgb(217_200_236/80%),transparent_32%)]"></div>
      <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <p class="inline-flex items-center gap-2 rounded-full bg-background-card/70 px-4 py-2 text-xs font-semibold uppercase text-primary-dark">
            <MessageCircle size={15} aria-hidden="true" />
            Liên hệ SUGONG
          </p>
        <h2 class="mt-2 font-heading text-3xl text-primary-dark">Bạn thích mẫu này?</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-text-secondary">
          Nhắn SUGONG qua Zalo, TikTok hoặc Threads để được tư vấn thêm về mẫu, giá và thời gian hoàn thiện.
        </p>
      </div>
        <Button class="gap-2" href={brand.channels.zalo}>
          <MessageCircle size={17} aria-hidden="true" />
          Nhắn Zalo để tư vấn
        </Button>
      </div>
      <Sparkles className="pointer-events-none absolute bottom-6 right-8 hidden text-primary-soft md:block" size={52} aria-hidden="true" />
    </div>
  </Container>
</section>
