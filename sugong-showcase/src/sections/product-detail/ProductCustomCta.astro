---
import Button from "../../components/ui/Button.astro";
import Container from "../../components/ui/Container.astro";
import { brand } from "../../lib/site-data";
---

<section class="bg-background-section py-section-mobile">
  <Container>
    <div class="grid gap-5 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="text-sm font-semibold uppercase text-primary-dark">Custom cùng SUGONG</p>
        <h2 class="mt-2 font-heading text-3xl text-primary-dark">Muốn đổi màu hoặc thêu tên riêng?</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-text-secondary">
          Gửi ý tưởng qua Zalo, SUGONG sẽ tư vấn chất liệu, màu sắc và thời gian hoàn thiện trước khi làm.
        </p>
      </div>
      <Button href={brand.channels.zalo}>Nhắn Zalo</Button>
    </div>
  </Container>
</section>
