---
import { Palette, Sparkles } from "lucide-react";
import type { GraduationHat } from "../../domain/graduation-hat/graduation-hat.types";
import { graduationHatTones } from "../../domain/graduation-hat/graduation-hat.types";
import { getCloudinaryImageProps } from "../../lib/cloudinary-image";
import { withBase } from "../../lib/url";

interface Props {
  hats: GraduationHat[];
}

const { hats } = Astro.props;
const initialVisibleCount = 8;
const visibleStep = 8;
---

<section
  class="bg-background-main py-section-mobile lg:py-section-desktop"
  data-graduation-hat-gallery
  data-initial-count={initialVisibleCount}
  data-step-count={visibleStep}
>
  <div class="mx-auto w-full max-w-page px-5 sm:px-6 lg:px-8">
    <div class="-mx-5 overflow-x-auto px-5 sm:mx-0 sm:px-0">
      <div class="flex min-w-max gap-3">
        {graduationHatTones.map((item) => (
          <button
            class:list={[
              "inline-flex min-h-10 items-center justify-center gap-2 rounded-full border px-4 text-sm font-medium transition",
              item.value === "all"
                ? "border-primary bg-primary text-background-card shadow-soft"
                : "border-primary-soft/70 bg-background-card text-primary-dark hover:border-primary-soft hover:bg-background-section",
            ]}
            type="button"
            aria-pressed={item.value === "all" ? "true" : "false"}
            data-tone-filter={item.value}
          >
            <Palette size={15} aria-hidden="true" />
            {item.label}
          </button>
        ))}
      </div>
    </div>

    <div class="mt-7 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4 xl:gap-5">
      {hats.map((hat, index) => {
        const toneLabel = graduationHatTones.find((item) => item.value === hat.tone)?.label ?? "Khác";
        const imageProps = getCloudinaryImageProps(hat.coverImage, "hat-card");

        return (
          <article
            class:list={[
              "group overflow-hidden rounded-card border border-primary-soft/40 bg-background-card shadow-soft transition duration-300 hover:-translate-y-1 hover:shadow-feather",
              index >= initialVisibleCount && "hidden",
            ]}
            data-hat-card
            data-tone={hat.tone}
          >
            <a class="block" href={withBase(`/products/graduation-hats/${hat.slug}`)} aria-label={`Xem mẫu ${hat.name}`}>
              <div class="aspect-[4/5] overflow-hidden bg-background-section">
                <img
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.025]"
                  src={imageProps.src}
                  srcset={imageProps.srcset}
                  sizes={imageProps.sizes}
                  alt={hat.coverImage.alt}
                  width={imageProps.width}
                  height={imageProps.height}
                  loading={index < initialVisibleCount ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={index < 2 ? "high" : "auto"}
                />
              </div>
              <div class="space-y-2 p-4">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-background-section px-3 py-1 text-[11px] font-semibold text-primary-dark">
                  <Sparkles size={13} aria-hidden="true" />
                  {toneLabel}
                </span>
                <h2 class="font-heading text-xl leading-snug text-primary-dark">{hat.name}</h2>
                <p class="line-clamp-2 text-xs leading-5 text-text-secondary">{hat.shortDescription}</p>
                <p class="text-sm font-medium text-primary-dark">Xem mẫu</p>
              </div>
            </a>
          </article>
        );
      })}
    </div>

    <div class="mt-8 hidden rounded-card border border-primary-soft/40 bg-background-card p-8 text-center shadow-soft" data-empty-state>
      <p class="font-heading text-3xl text-primary-dark">Chưa có mẫu phù hợp</p>
      <p class="mt-3 text-sm text-text-secondary">Bạn thử chọn tone khác hoặc nhắn SUGONG để trao đổi mẫu riêng.</p>
    </div>

    {hats.length > initialVisibleCount && (
      <div class="mt-8 flex justify-center" data-load-more-wrap>
        <button
          class="inline-flex min-h-11 items-center justify-center rounded-full border border-primary-soft bg-background-card px-5 text-sm font-medium text-primary-dark shadow-soft transition hover:bg-background-section"
          type="button"
          data-load-more-button
        >
          Xem thêm mẫu
        </button>
      </div>
    )}
  </div>

  <script>
    (() => {
      const root = document.querySelector("[data-graduation-hat-gallery]");
      if (!root) return;

      const buttons = Array.from(root.querySelectorAll("[data-tone-filter]"));
      const cards = Array.from(root.querySelectorAll("[data-hat-card]"));
      const emptyState = root.querySelector("[data-empty-state]");
      const loadMoreWrap = root.querySelector("[data-load-more-wrap]");
      const loadMoreButton = root.querySelector("[data-load-more-button]");
      const initialVisibleCount = Number(root.getAttribute("data-initial-count") || "8");
      const visibleStep = Number(root.getAttribute("data-step-count") || "8");

      const params = new URLSearchParams(window.location.search);
      let activeTone = params.get("tone") || "all";
      let visibleLimit = initialVisibleCount;

      function getMatchingCards(tone: string) {
        return cards.filter((card) => tone === "all" || card.getAttribute("data-tone") === tone);
      }

      function updateLoadMore(totalMatchingCards: number) {
        if (!(loadMoreWrap instanceof HTMLElement) || !(loadMoreButton instanceof HTMLButtonElement)) return;

        const remaining = totalMatchingCards - visibleLimit;
        const hasMore = remaining > 0;
        loadMoreWrap.classList.toggle("hidden", !hasMore);

        if (hasMore) {
          loadMoreButton.textContent = `Xem thêm ${Math.min(visibleStep, remaining)} mẫu`;
        }
      }

      function render() {
        buttons.forEach((button) => {
          const active = button.getAttribute("data-tone-filter") === activeTone;
          button.setAttribute("aria-pressed", String(active));
          button.classList.toggle("border-primary", active);
          button.classList.toggle("bg-primary", active);
          button.classList.toggle("text-background-card", active);
          button.classList.toggle("shadow-soft", active);
          button.classList.toggle("border-primary-soft/70", !active);
          button.classList.toggle("bg-background-card", !active);
          button.classList.toggle("text-primary-dark", !active);
        });

        const matchingCards = getMatchingCards(activeTone);

        cards.forEach((card) => {
          card.classList.add("hidden");
        });

        matchingCards.slice(0, visibleLimit).forEach((card) => {
          card.classList.remove("hidden");
        });

        emptyState?.classList.toggle("hidden", matchingCards.length > 0);
        updateLoadMore(matchingCards.length);
      }

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const tone = button.getAttribute("data-tone-filter") || "all";
          const query = tone === "all" ? "" : `?tone=${tone}`;
          window.history.pushState({}, "", `${window.location.pathname}${query}`);
          activeTone = tone;
          visibleLimit = initialVisibleCount;
          render();
        });
      });

      if (loadMoreButton instanceof HTMLButtonElement) {
        loadMoreButton.addEventListener("click", () => {
          visibleLimit += visibleStep;
          render();
        });
      }

      render();
    })();
  </script>
</section>
