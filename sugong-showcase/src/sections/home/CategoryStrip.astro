---
import Container from "../../components/ui/Container.astro";

type Category = {
  name: string;
  href: string;
  image: string;
  alt: string;
};

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
const icons = ["▢", "✿", "□", "✎"];
const positions = ["18% center", "center", "center", "center"];
---

<section class="-mt-1 bg-background-card py-7 lg:py-9">
  <Container class="max-w-wide">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-grid">
      {categories.map((category, index) => (
        <a
          class="group overflow-hidden rounded-card bg-background-card shadow-feather ring-1 ring-primary-soft/20 transition hover:-translate-y-1 hover:ring-primary-soft/35"
          href={category.href}
        >
          <div class="aspect-[1.45/1] overflow-hidden bg-background-section">
            <img
              class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.025]"
              style={`object-position: ${positions[index]};`}
              src={category.image}
              alt={category.alt}
              width="900"
              height="620"
              loading="lazy"
            />
          </div>
          <div class="relative p-4 pt-8">
            <span class="absolute -top-6 left-4 flex h-12 w-12 items-center justify-center rounded-full bg-background-main text-2xl text-primary-dark shadow-feather ring-1 ring-primary-soft/25">
              {icons[index]}
            </span>
            <p class="font-heading text-2xl text-primary-dark">{category.name}</p>
            <p class="mt-2 text-sm font-medium text-primary-dark">Xem ngay <span aria-hidden="true">→</span></p>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
