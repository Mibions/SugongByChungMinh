---
import Container from "../../components/ui/Container.astro";
import { getCloudinaryImageProps } from "../../lib/cloudinary-image";
import { withBase } from "../../lib/url";
import { Gift, PenLine, ShoppingBag, Sparkles } from "lucide-react";

type Category = {
  name: string;
  href: string;
  image: string;
  alt: string;
};

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
const icons = [ShoppingBag, Sparkles, Gift, PenLine];
const positions = ["18% center", "center", "center", "center"];
---

<section class="-mt-1 bg-background-card py-7 lg:py-9">
  <Container class="max-w-wide">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-grid">
      {categories.map((category, index) => {
        const Icon = icons[index] ?? Sparkles;
        const imageProps = getCloudinaryImageProps(
          { url: category.image, width: 900, height: 620 },
          "category-card",
        );

        return (
          <a
            class="group overflow-hidden rounded-card border border-primary-soft/35 bg-background-card shadow-soft transition hover:-translate-y-1 hover:border-primary-soft hover:shadow-feather"
            href={withBase(category.href)}
          >
            <div class="aspect-[1.45/1] overflow-hidden bg-background-section">
              <img
                class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.025]"
                style={`object-position: ${positions[index]};`}
                src={imageProps.src}
                srcset={imageProps.srcset}
                sizes={imageProps.sizes}
                alt={category.alt}
                width={imageProps.width}
                height={imageProps.height}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="relative p-4 pt-8">
              <span class="absolute -top-6 left-4 flex h-12 w-12 items-center justify-center rounded-full bg-background-main text-primary-dark shadow-feather ring-1 ring-primary-soft/25">
                <Icon size={21} aria-hidden="true" />
              </span>
              <p class="font-heading text-2xl text-primary-dark">{category.name}</p>
              <p class="mt-2 inline-flex items-center gap-2 text-sm font-medium text-primary-dark">
                Xem ngay <Sparkles size={14} aria-hidden="true" />
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </Container>
</section>
