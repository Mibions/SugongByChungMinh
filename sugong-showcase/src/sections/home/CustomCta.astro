---
import Button from "../../components/ui/Button.astro";
import Container from "../../components/ui/Container.astro";
import { brand } from "../../lib/site-data";
---

<section class="bg-background-card pb-section-mobile">
  <Container class="max-w-wide">
    <div class="overflow-hidden rounded-card bg-background-section shadow-feather ring-1 ring-primary-soft/25">
      <div class="grid gap-6 md:grid-cols-[1fr_1.2fr_auto] md:items-center">
        <div class="min-h-28 bg-background-section">
          <img
            class="h-full min-h-28 w-full object-cover"
            src="/assets/brand/footer-bag.png"
            alt="Túi lavender handmade trên nền hoa tím"
            width="2048"
            height="640"
            loading="lazy"
          />
        </div>
        <div class="px-5 py-5 md:px-0">
          <p class="text-xs font-semibold uppercase text-primary-dark">Custom theo ý bạn</p>
          <h2 class="mt-2 font-heading text-3xl text-primary-dark">Bạn có ý tưởng riêng?</h2>
          <p class="mt-2 text-sm leading-6 text-text-secondary">
            SUGONG giúp bạn biến nó thành món quà độc đáo.
          </p>
        </div>
        <div class="px-5 pb-5 md:px-6 md:pb-0">
          <Button href={brand.channels.zalo}>Chat với chúng mình trên Zalo</Button>
        </div>
      </div>
    </div>
  </Container>
</section>
