---
import { MessageCircle, Sparkles, WandSparkles } from "lucide-react";
import Button from "../../components/ui/Button.astro";
import Container from "../../components/ui/Container.astro";
import { brand } from "../../lib/site-data";
import { withBase } from "../../lib/url";
---

<section class="bg-background-card pb-section-mobile">
  <Container class="max-w-wide">
    <div class="relative isolate overflow-hidden rounded-card border border-primary-soft/30 bg-[linear-gradient(135deg,#fffaf5_0%,#f4edff_48%,#fff6fb_100%)] shadow-feather">
      <img
        class="pointer-events-none absolute inset-y-0 right-0 z-[-1] hidden h-full w-[46%] object-cover object-center opacity-35 md:block"
        style="-webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%); mask-image: linear-gradient(to left, black 0%, transparent 100%);"
        src={withBase("/assets/brand/footer-bag.png")}
        alt=""
        width="2048"
        height="640"
        loading="lazy"
      />
      <div class="grid gap-6 px-6 py-8 md:grid-cols-[1fr_auto] md:items-center md:px-10 lg:px-12 lg:py-10">
        <div class="max-w-2xl">
          <p class="inline-flex items-center gap-2 rounded-full bg-background-card/75 px-4 py-2 text-xs font-semibold uppercase text-primary-dark shadow-soft">
            <WandSparkles size={15} aria-hidden="true" />
            Custom theo ý bạn
          </p>
          <h2 class="mt-4 font-heading text-3xl text-primary-dark md:text-4xl">
            Bạn có ý tưởng riêng?
          </h2>
          <p class="mt-3 text-sm leading-6 text-text-secondary md:text-base">
            SUGONG giúp bạn biến nó thành món quà độc đáo, mềm mại và có dấu ấn rất riêng.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row md:flex-col lg:flex-row">
          <Button href={brand.channels.zalo}>
            <span class="inline-flex items-center gap-2">
              <MessageCircle size={18} aria-hidden="true" />
              Chat với chúng mình trên Zalo
            </span>
          </Button>
          <span class="inline-flex items-center gap-2 rounded-full bg-background-card/70 px-4 py-3 text-sm font-semibold text-primary-dark shadow-soft">
            <Sparkles size={16} aria-hidden="true" />
            Tư vấn trước khi làm
          </span>
        </div>
      </div>
    </div>
  </Container>
</section>
