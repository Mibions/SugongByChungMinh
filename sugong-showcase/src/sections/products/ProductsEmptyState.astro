---
import Button from "../../components/ui/Button.astro";
import { brand } from "../../lib/site-data";
import { SearchX, Sparkles } from "lucide-react";
---

<div class="rounded-card border border-primary-soft/60 bg-background-card p-8 text-center shadow-soft">
  <div class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-background-section text-primary-dark">
    <SearchX size={26} aria-hidden="true" />
  </div>
  <p class="mt-5 font-heading text-3xl text-primary-dark">Chưa có sản phẩm phù hợp</p>
  <p class="mx-auto mt-3 max-w-xl text-sm leading-7 text-text-secondary">
    Bạn có thể thử đổi bộ lọc hoặc nhắn SUGONG để custom theo ý tưởng riêng.
  </p>
  <div class="mt-6 flex flex-wrap justify-center gap-3">
    <Button href="/products" variant="secondary">
      <Sparkles size={16} aria-hidden="true" />
      Xem tất cả sản phẩm
    </Button>
    <Button href={brand.channels.zalo}>Tư vấn custom</Button>
  </div>
</div>
