---
import type { ProductCategory, ProductQuery } from "../../domain/product/product.types";
import { withBase } from "../../lib/url";
import { ArrowUpDown, Search, SlidersHorizontal } from "lucide-react";

interface Props {
  activeCategory: ProductCategory | "all";
  search?: string;
  sort: NonNullable<ProductQuery["sort"]>;
  total: number;
}

const { activeCategory, search = "", sort, total } = Astro.props;
---

<form class="rounded-card border border-primary-soft/50 bg-background-card/90 p-4 shadow-soft" method="get" action={withBase("/products")}>
  {activeCategory !== "all" && <input type="hidden" name="category" value={activeCategory} />}
  <div class="grid gap-4 md:grid-cols-[1fr_auto] md:items-center">
    <p class="flex items-center text-sm font-medium text-primary-dark">
      <span class="font-heading text-2xl">{total}</span>
      <span class="ml-2 text-text-secondary">sản phẩm</span>
    </p>

    <div class="grid gap-3 sm:grid-cols-[minmax(220px,1fr)_auto_auto] sm:items-center">
      <div class="relative">
        <Search className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-primary-soft" size={17} aria-hidden="true" />
        <label class="sr-only" for="product-search">Tìm sản phẩm</label>
        <input
          id="product-search"
          class="min-h-12 w-full rounded-full border border-border bg-background-card px-11 text-sm text-text-primary outline-none transition placeholder:text-text-secondary focus:border-primary-soft"
          type="search"
          name="q"
          value={search}
          placeholder="Tìm mẫu handmade..."
        />
      </div>

      <div class="relative">
        <ArrowUpDown className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-primary-soft" size={16} aria-hidden="true" />
        <label class="sr-only" for="product-sort">Sắp xếp</label>
        <select
          id="product-sort"
          class="min-h-12 w-full appearance-none rounded-full border border-border bg-background-card px-10 pr-8 text-sm text-text-primary outline-none transition focus:border-primary-soft sm:w-48"
          name="sort"
        >
          <option value="newest" selected={sort === "newest"}>Mới nhất</option>
          <option value="price-asc" selected={sort === "price-asc"}>Giá thấp đến cao</option>
          <option value="price-desc" selected={sort === "price-desc"}>Giá cao đến thấp</option>
        </select>
      </div>

      <button class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-primary-soft bg-background-section px-5 text-sm font-medium text-primary-dark transition hover:bg-background-card" type="submit">
        <SlidersHorizontal size={16} aria-hidden="true" />
        Lọc
      </button>
    </div>
  </div>
</form>
