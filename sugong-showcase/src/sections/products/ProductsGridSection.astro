---
import ProductCard from "../../components/product/ProductCard.astro";
import Container from "../../components/ui/Container.astro";
import type { Product } from "../../domain/product/product.types";
import type { ProductCategory, ProductQuery } from "../../domain/product/product.types";
import ProductsSidebar from "./ProductsSidebar.astro";
import ProductsToolbar from "./ProductsToolbar.astro";

type PaginationLink = {
  label: string;
  href: string;
  active?: boolean;
};

interface Props {
  products: Product[];
  paginationLinks: PaginationLink[];
  activeCategory: ProductCategory | "all";
  search?: string;
  sort: NonNullable<ProductQuery["sort"]>;
  total: number;
  nextHref?: string;
}

const { products, paginationLinks, activeCategory, search = "", sort, total, nextHref } = Astro.props;
---

<section class="py-section-mobile lg:py-section-desktop">
  <Container>
    <details class="mb-5 rounded-card border border-primary-soft/60 bg-background-card p-4 shadow-soft lg:hidden">
      <summary class="cursor-pointer text-sm font-medium text-primary-dark">Mở bộ lọc</summary>
      <div class="mt-4 grid gap-3 text-sm text-text-secondary">
        <p>Khoảng giá: 0đ - 600.000đ</p>
        <p>Màu sắc: Lavender, hồng nhạt, kem</p>
        <p>Sản phẩm custom và handmade được ưu tiên hiển thị trong bộ sưu tập.</p>
      </div>
    </details>

    <div class="grid gap-7 lg:grid-cols-[280px_1fr] xl:grid-cols-[300px_1fr]">
      <ProductsSidebar />
      <div class="space-y-7">
        <ProductsToolbar activeCategory={activeCategory} search={search} sort={sort} total={total} />

        {
          products.length > 0 ? (
            <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3 xl:gap-8">
              {products.map((product) => <ProductCard product={product} />)}
            </div>
          ) : (
            <div class="rounded-card border border-primary-soft/60 bg-background-card p-8 text-center shadow-soft">
              <p class="font-heading text-2xl text-text-primary">Chưa tìm thấy sản phẩm phù hợp</p>
              <p class="mt-3 text-sm text-text-secondary">Thử đổi từ khóa hoặc chọn lại danh mục.</p>
            </div>
          )
        }

        {paginationLinks.length > 1 && (
          <nav class="flex items-center justify-center gap-2 pt-2" aria-label="Phân trang sản phẩm">
            {paginationLinks.map((link) => (
              <a
                class:list={[
                  "flex h-10 min-w-10 items-center justify-center rounded-button border px-3 text-sm font-medium transition",
                  link.active
                    ? "border-primary-soft bg-primary text-background-card"
                    : "border-primary-soft bg-background-card text-primary-dark hover:bg-background-section",
                ]}
                href={link.href}
                aria-current={link.active ? "page" : undefined}
              >
                {link.label}
              </a>
            ))}
            {nextHref && (
              <a
                class="flex h-10 min-w-10 items-center justify-center rounded-button border border-primary-soft bg-background-card px-3 text-sm font-medium text-primary-dark transition hover:bg-background-section"
                href={nextHref}
                aria-label="Trang tiếp theo"
              >
                Tiếp
              </a>
            )}
          </nav>
        )}
      </div>
    </div>
  </Container>
</section>
