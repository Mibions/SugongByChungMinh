---
import { Palette, Scissors, SlidersHorizontal, Tags, WandSparkles } from "lucide-react";

const colors = ["bg-primary", "bg-accent-pink", "bg-accent-cream", "bg-primary-soft", "bg-success"];
---

<aside class="hidden lg:block">
  <div class="space-y-6 rounded-card border border-primary-soft/60 bg-background-card/90 p-6 shadow-soft">
    <div class="flex items-center gap-3">
      <span class="grid h-10 w-10 place-items-center rounded-full bg-background-section text-primary-dark">
        <SlidersHorizontal size={18} aria-hidden="true" />
      </span>
      <div>
        <p class="font-heading text-xl text-primary-dark">Bộ lọc</p>
        <p class="text-xs text-text-secondary">Tinh gọn theo phong cách bạn thích</p>
      </div>
    </div>

    <div class="border-t border-border pt-6">
      <p class="flex items-center gap-2 font-medium text-primary-dark">
        <Tags size={17} aria-hidden="true" />
        Khoảng giá
      </p>
      <div class="mt-4 h-1.5 rounded-full bg-primary-soft">
        <div class="h-full w-full rounded-full bg-primary"></div>
      </div>
      <div class="mt-3 flex justify-between text-xs text-text-secondary">
        <span>0đ</span>
        <span>600.000đ</span>
      </div>
    </div>

    <div class="border-t border-border pt-6">
      <p class="flex items-center gap-2 font-medium text-primary-dark">
        <Palette size={17} aria-hidden="true" />
        Màu sắc
      </p>
      <div class="mt-4 flex items-center gap-3">
        {colors.map((color) => <span class:list={["h-6 w-6 rounded-full", color]} aria-hidden="true" />)}
      </div>
    </div>

    <div class="border-t border-border pt-6">
      <p class="flex items-center gap-2 font-medium text-primary-dark">
        <WandSparkles size={17} aria-hidden="true" />
        Sản phẩm custom
      </p>
      <div class="mt-4 grid gap-3 text-sm text-text-secondary">
        <p class="flex items-center gap-3 rounded-button bg-background-section px-3 py-2">
          <Scissors size={16} className="text-primary-dark" aria-hidden="true" />
          Handmade with love
        </p>
        <p class="flex items-center gap-3 rounded-button bg-background-section px-3 py-2">
          <WandSparkles size={16} className="text-primary-dark" aria-hidden="true" />
          Có thể cá nhân hóa
        </p>
      </div>
    </div>
  </div>
</aside>
